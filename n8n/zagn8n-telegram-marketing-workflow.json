        "sendBody": true,
        "specifyBody": "json",
        "jsonBody": "={{ { model: 'gpt-5.2', instructions: 'Rewrite the ZagChain draft using the edit request. Keep it concise, compliant, and plain text only.', input: `Original draft:\\n${$json.draft_text}\\n\\nPerformance summary:\\n${$json.performance_summary}\\n\\nEdit request:\\n${$json.edit_request_incoming}` } }}",
        "options": {}
      },
      "id": "09628bfb-c4d4-4d84-bcf5-726f1223454f",
      "name": "Regenerate Draft",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.2,
