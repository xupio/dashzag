    {
      "parameters": {
        "jsCode": "const approved = $('Prepare Approve Update').first().json;\nconst design = $json.design || {};\nconst designId = design.id || '';\nconst editUrl = designId ? `https://www.canva.com/design/${designId}/edit` : '';\n\nreturn [{\n  json: {\n    ...approved,\n    canva_status: editUrl ? 'created' : 'create_failed',\n    canva_design_id: designId,\n    canva_design_link: editUrl,\n    last_action: editUrl ? 'canva_design_created' : 'canva_design_create_failed',\n    approval_message: editUrl\n      ? `zagn8n approved\\n\\nYour draft is approved and Canva created a social post design.\\n\\nApproved draft:\\n${approved.draft_text}\\n\\nCanva brief:\\n${approved.canva_brief}\\n\\nCanva link:\\n${editUrl}`\n      : `zagn8n approved\\n\\nThe draft was approved, but Canva did not return a design link.\\n\\nApproved draft:\\n${approved.draft_text}`\n  }\n}];"
      },
