    {
      "parameters": {
        "jsCode": "const latest = $('Find Latest Chat Draft').first().json;\nconst raw = $json.output?.[0]?.content?.[0]?.text || $json.output_text || '';\nconst revised = String(raw || '').trim();\nconst nextVersion = Number(latest.version || 1) + 1;\n\nreturn [{\n  json: {\n    ...latest,\n    draft_text: revised,\n    approval_status: 'needs_edit',\n    edit_request: latest.edit_request_incoming || '',\n    version: nextVersion,\n    last_action: 'revised_draft_sent',\n    revised_message: `zagn8n revised draft\\n\\nDraft:\\n${revised}\\n\\nReply with:\\napprove\\nor\\nedit: your change request`\n  }\n}];"
      },
      "id": "425b2fbb-f34b-4642-8c9e-97ae0f4d448c",
      "name": "Prepare Edited Draft Update",
      "type": "n8n-nodes-base.code",
