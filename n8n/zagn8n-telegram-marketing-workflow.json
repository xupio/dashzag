    {
      "parameters": {
        "jsCode": "const draft = String($json.draft_text || '').trim();\nconst performanceSummary = String($json.performance_summary || '').trim();\nconst titleDate = String($json.performance_date || '').trim() || new Date().toISOString().slice(0, 10);\n\nreturn [{\n  json: {\n    ...$json,\n    approval_status: 'approved',\n    canva_status: 'creating',\n    canva_design_id: '',\n    canva_design_link: '',\n    canva_title: `ZagChain Social Post ${titleDate}`,\n    canva_brief: `Create a premium ZagChain social post using this approved draft.\\n\\nPerformance summary:\\n${performanceSummary}\\n\\nApproved draft:\\n${draft}`,\n    last_action: 'approved_sending_to_canva'\n  }\n}];"
      },
