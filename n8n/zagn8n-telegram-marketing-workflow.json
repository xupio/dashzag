        "jsonBody": "={{ { design_type: { type: 'custom', width: 1080, height: 1080 }, title: $json.canva_title } }}",
        "options": {}
      },
      "id": "1e61f991-815c-448e-a3a6-0862e952d291",
      "name": "Create Canva Social Design",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.2,
      "position": [
        1400,
        120
      ]
