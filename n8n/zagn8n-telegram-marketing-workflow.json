      "id": "497d37b0-2d7f-4d91-8dc0-f6088aab5eec",
      "name": "Fetch Daily Performance",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.2,
      "position": [
        -300,
        -60
      ]
    },
    {
      "parameters": {
        "jsCode": "const trigger = $('Parse Telegram Command').first().json;\nconst feed = $json;\nconst totals = feed.totals || {};\nconst topPackages = Array.isArray(feed.top_packages) ? feed.top_packages : [];\nconst packageLine = topPackages.slice(0, 3).map((pkg) => `${pkg.name} (${pkg.monthly_return_rate || pkg.return_rate || 'rate listed'})`).join(', ');\nconst performanceSummary = `Verified users: ${totals.verified_user_count || 0}; active investors: ${totals.active_investor_count || 0}; active capital: $${totals.active_capital_usd || 0}; paid payouts: ${totals.paid_payout_count || 0}.`;\nconst prompt = `Create one premium but clear Telegram-ready marketing draft for ZagChain using only these facts. Avoid guarantees. Keep it concise and persuasive. Mention package examples naturally. Return plain text only.\\n\\nPerformance summary: ${performanceSummary}\\nPackage examples: ${packageLine || 'Use current dashboard package listings only.'}`;\n\nreturn [{\n  json: {\n    created_at: new Date().toISOString(),\n    chat_id: trigger.chat_id,\n    trigger_word: 'daily',\n    performance_date: String(feed.generated_at || new Date().toISOString()).slice(0, 10),\n    performance_summary: performanceSummary,\n    ai_prompt: prompt,\n    version: 1,\n    package_line: packageLine\n  }\n}];"
      },
      "id": "2b9e9bb2-7cbf-4633-8e06-34afd1664355",
      "name": "Build Daily Draft Prompt",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        -20,
        -60
      ]
    },
    {
      "parameters": {
        "url": "https://api.openai.com/v1/responses",
        "sendHeaders": true,
        "headerParameters": {
          "parameters": [
            {
              "name": "Authorization",
              "value": "=Bearer replace-with-your-openai-api-key"
            },
            {
              "name": "Content-Type",
              "value": "application/json"
            }
          ]
        },
        "sendBody": true,
        "specifyBody": "json",
        "jsonBody": "={{ { model: 'gpt-5.2', instructions: 'You write compliant marketing copy for ZagChain. No guarantees. Plain text only.', input: $json.ai_prompt } }}",
        "options": {}
      },
      "id": "81877fc3-12ea-4f26-839d-0f688915d884",
      "name": "Generate Daily Draft",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.2,
      "position": [
        260,
        -60
      ]
    },
    {
      "parameters": {
        "jsCode": "const ctx = $('Build Daily Draft Prompt').first().json;\nconst raw = $json.output?.[0]?.content?.[0]?.text || $json.output_text || '';\nconst draft = String(raw || '').trim();\nconst draftMessage = `zagn8n draft ready\\n\\nPerformance summary:\\n${ctx.performance_summary}\\n\\nDraft:\\n${draft}\\n\\nReply with:\\napprove\\nor\\nedit: your change request`;\n\nreturn [{\n  json: {\n    created_at: ctx.created_at,\n    chat_id: ctx.chat_id,\n    trigger_word: ctx.trigger_word,\n    performance_date: ctx.performance_date,\n    performance_summary: ctx.performance_summary,\n    draft_text: draft,\n    approval_status: 'draft',\n    edit_request: '',\n    version: ctx.version,\n    canva_status: 'not_started',\n    canva_design_id: '',\n    canva_design_link: '',\n    last_action: 'draft_sent',\n    telegram_message: draftMessage\n  }\n}];"
      },
