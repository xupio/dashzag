    {
      "parameters": {
        "jsCode": "const commandCtx = $('Parse Telegram Command').first().json;\nconst rows = items.map((item) => item.json).filter((row) => String(row.chat_id || '') === String(commandCtx.chat_id || ''));\nrows.sort((a, b) => String(b.created_at || '').localeCompare(String(a.created_at || '')));\nconst latest = rows[0];\n\nif (!latest) {\n  return [{ json: { chat_id: commandCtx.chat_id, error_message: 'No active draft found for this chat. Send `daily` first.' } }];\n}\n\nreturn [{\n  json: {\n    ...latest,\n    chat_id: commandCtx.chat_id,\n    command: commandCtx.command,\n    edit_request_incoming: commandCtx.edit_request,\n    telegram_text: commandCtx.telegram_text\n  }\n}];"
      },
